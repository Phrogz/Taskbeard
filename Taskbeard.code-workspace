{
  "folders": [
    {
      "path": "."
    }
  ],
  "settings": {
    "vitest.rootConfig": "frontend/vite.config.ts",
    "vitest.vitestPackagePath": "frontend/node_modules/vitest/package.json",
    "testing.automaticallyOpenTestResults": "openOnTestFailure",
    "explorer.excludeGitIgnore": true,
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": ["tests"]
  },
  "extensions": {
    "recommendations": [
      "vitest.explorer",
      "ms-python.python"
    ]
  }
}
